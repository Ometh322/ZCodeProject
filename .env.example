# ===== Server =====
# Port for the Express + Socket.IO server
PORT=4000

# Password to access /admin (simple bearer-token auth)
ADMIN_PASSWORD=123

# TTL of the admin session token, in seconds (default 12h)
ADMIN_TOKEN_TTL=43200

# SQLite file location (relative to server/)
DATABASE_URL="file:./dev.db"

# Comma-separated list of allowed CORS origins (frontend dev server etc.)
# For local dev: http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ===== Client (Vite) =====
# Where the API/socket server lives. Empty string => same origin (production build).
VITE_API_URL=http://localhost:4000
